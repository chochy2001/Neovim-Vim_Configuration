" ~/.ideavimrc - Synced with Neovim
" Compatible with macOS, Linux, Windows
" Configuration synced with Neovim for a consistent workflow

" -----------------------------------------------------------------------------
" Leader and Basic Configuration
" -----------------------------------------------------------------------------
let mapleader = " "
set number
set relativenumber
set tabstop=4
set shiftwidth=4
set expandtab
set smartindent
set scrolloff=8
set cursorline
set colorcolumn=80
set clipboard=unnamedplus
set laststatus=2
set showcmd
set noshowmode
set timeoutlen=300
set splitright
set splitbelow
set nowrap

" Plugin Emulations
set surround

" -----------------------------------------------------------------------------
" Search
" -----------------------------------------------------------------------------
set incsearch
set hlsearch
set ignorecase
set smartcase
nnoremap <leader><leader> :nohl<CR>

" -----------------------------------------------------------------------------
" Core Mappings and Basic Navigation
" -----------------------------------------------------------------------------
inoremap jj <Esc>

" IDE Navigation History - synced with Neovim
nnoremap <leader>b :action Back<CR>
nnoremap <leader>f :action Forward<CR>

" Split Navigation (w prefix)
nnoremap <leader>wh <C-w>h
nnoremap <leader>wj <C-w>j
nnoremap <leader>wk <C-w>k
nnoremap <leader>wl <C-w>l

" Move Lines - synced with Neovim
nnoremap <A-j> :m .+1<CR>==
nnoremap <A-k> :m .-2<CR>==
vnoremap <A-j> :m '>+1<CR>gv=gv
vnoremap <A-k> :m '<-2<CR>gv=gv

" Visual Mode Indentation
vnoremap > >gv
vnoremap < <gv

" Center Screen on Movements
nnoremap n nzz
nnoremap N Nzz
nnoremap * *zz
nnoremap # #zz
nnoremap g* g*zz
nnoremap g# g#zz

" Uppercase/Lowercase Conversion (Visual)
vnoremap <leader>u gu
vnoremap <leader>U gU

" -----------------------------------------------------------------------------
" Telescope Emulation (File Search/Navigation)
" -----------------------------------------------------------------------------
nnoremap <leader>ff :action GotoFile<CR>
nnoremap <leader>fg :action FindInPath<CR>
nnoremap <leader>fo :action RecentFiles<CR>
nnoremap <leader>fb :action Switcher<CR>
nnoremap <leader>fh :action HelpTopics<CR>
nnoremap <leader>fc :action GotoAction<CR>
nnoremap <leader>fk :action GotoAction<CR>
nnoremap <leader>ps :action GotoSymbol<CR>
nnoremap <leader>. :action GotoFile<CR>
nnoremap ,, :action GotoFile<CR>

" -----------------------------------------------------------------------------
" Neo-tree Emulation (Project View)
" -----------------------------------------------------------------------------
nnoremap <leader>pv :action ActivateProjectToolWindow<CR>
nnoremap <leader>fr :action SelectInProjectView<CR>
nnoremap <leader>pe :action ActivateProjectToolWindow<CR>
nnoremap <leader>bf :action Switcher<CR>

" -----------------------------------------------------------------------------
" Harpoon Emulation (Quick Marks) - synced with harpoon.lua
" -----------------------------------------------------------------------------
nnoremap <leader>mh :action ShowBookmarks<CR>
nnoremap <leader>ma :action ToggleBookmark<CR>
nnoremap <leader>mp :action GotoPreviousBookmark<CR>
nnoremap <leader>mn :action GotoNextBookmark<CR>
nnoremap <leader>1 '1
nnoremap <leader>2 '2
nnoremap <leader>3 '3
nnoremap <leader>4 '4
nnoremap <leader>5 '5
nnoremap <leader>6 '6
nnoremap <leader>7 '7
nnoremap <leader>8 '8
nnoremap <leader>9 '9

" -----------------------------------------------------------------------------
" Buffer / IDE Tab Management
" -----------------------------------------------------------------------------
nnoremap <S-l> :action NextTab<CR>
nnoremap <S-h> :action PreviousTab<CR>
nnoremap <space>l :action NextSplitter<CR>
nnoremap <space>h :action PrevSplitter<CR>
nnoremap <leader>bn :action NextTab<CR>
nnoremap <leader>bp :action PreviousTab<CR>
nnoremap <leader>bd :action CloseContent<CR>
nnoremap <leader>bl :action CloseAllToTheRight<CR>
nnoremap <leader>bh :action CloseAllToTheLeft<CR>
nnoremap <leader>to :action CloseAllEditorsButActive<CR>

" -----------------------------------------------------------------------------
" Integrated Terminal
" -----------------------------------------------------------------------------
nnoremap <leader>tt :action ActivateTerminalToolWindow<CR>
tnoremap <C-[><C-[> <C-w><C-p>
tnoremap jj <C-w><C-p>

" -----------------------------------------------------------------------------
" Git / VCS (Version Control) - synced with git-stuff.lua
" -----------------------------------------------------------------------------

" Common Actions
nnoremap <leader>gs :action ActivateVersionControlToolWindow<CR>
nnoremap <leader>gc :action CheckinProject<CR>
nnoremap <leader>gp :action Vcs.Push<CR>
nnoremap <leader>gl :action Vcs.UpdateProject<CR>
nnoremap <leader>gf :action Git.Fetch<CR>

" History and Diffs
nnoremap <leader>gh :action Vcs.ShowTabbedFileHistory<CR>
nnoremap <leader>ghd :action Git.Log.Show.Details<CR>
nnoremap <leader>gb :action Annotate<CR>
nnoremap <leader>gbl :action Annotate<CR>
nnoremap <leader>gbr :action Git.Branches<CR>
nnoremap <leader>gbc :action Git.CompareWithBranch<CR>
nnoremap <leader>gd :action Compare.SameVersion<CR>

" Hunk Navigation - synced with gitsigns in Neovim
nnoremap <leader>gn :action VcsShowNextChangeMarker<CR>
nnoremap <leader>gnp :action VcsShowPrevChangeMarker<CR>

" GitSigns Commands - synced with git-stuff.lua
nnoremap <leader>gsa :action ChangesView.Shelve<CR>
nnoremap <leader>gsr :action Vcs.RollbackChangedLines<CR>
nnoremap <leader>gsu :action Vcs.RollbackChangedLines<CR>
nnoremap <leader>gsb :action ChangesView.Revert<CR>
nnoremap <leader>gbt :action Annotate<CR>
nnoremap <leader>gdd :action Vcs.Show.Local.Changes<CR>

" Diffview Commands - synced with Neovim
nnoremap <leader>gdo :action Compare.LastVersion<CR>
nnoremap <leader>gdq :action CloseContent<CR>
nnoremap <leader>gdh :action Vcs.ShowTabbedFileHistory<CR>
nnoremap <leader>gdf :action ActivateVersionControlToolWindow<CR>

" Git Conflict Commands - synced with git-stuff.lua (gc* prefix)
nnoremap <leader>gco :action ChooseOurs<CR>
nnoremap <leader>gct :action ChooseTheirs<CR>
nnoremap <leader>gcb :action ChooseBoth<CR>
nnoremap <leader>gcn :action ChooseNone<CR>
nnoremap <leader>gcp :action VcsShowPrevChangeMarker<CR>
nnoremap <leader>gcnn :action VcsShowNextChangeMarker<CR>

" -----------------------------------------------------------------------------
" Undotree Emulation
" -----------------------------------------------------------------------------
nnoremap <leader>u :action LocalHistory.ShowHistory<CR>

" -----------------------------------------------------------------------------
" Formatting and Comments
" -----------------------------------------------------------------------------
nnoremap gcc :action CommentByLineComment<CR>
vnoremap gc :action CommentByLineComment<CR>

" -----------------------------------------------------------------------------
" LSP / Smart Code Actions - synced with lsp-config.lua
" -----------------------------------------------------------------------------
nnoremap K  :action QuickJavaDoc<CR>
nnoremap gd :action GotoDeclaration<CR>
nnoremap gi :action GotoImplementation<CR>
nnoremap go :action GotoTypeDeclaration<CR>
nnoremap gr :action FindUsages<CR>
nnoremap gs :action ParameterInfo<CR>
nnoremap gR :action FindUsages<CR>

nnoremap <leader>ca :action ShowIntentionActions<CR>
inoremap <C-space> <C-x><C-o>
nnoremap <leader>fm :action OptimizeImports<CR>
nnoremap <leader>rn :action RenameElement<CR>
nnoremap <leader>lw :action Bookmarks<CR>

" -----------------------------------------------------------------------------
" Trouble Emulation (Problems/Errors List)
" -----------------------------------------------------------------------------
nnoremap <leader>xx :action ActivateProblemsViewToolWindow<CR>
nnoremap <leader>xw :action ActivateProblemsViewToolWindow<CR>
nnoremap <leader>xd :action ActivateProblemsViewToolWindow<CR>
nnoremap <leader>xl :action ActivateProblemsViewToolWindow<CR>
nnoremap <leader>xq :action ActivateProblemsViewToolWindow<CR>
nnoremap <leader>xn :action GotoNextError<CR>
nnoremap <leader>xp :action GotoPreviousError<CR>

" -----------------------------------------------------------------------------
" Folding - synced with vim-options.lua
" -----------------------------------------------------------------------------
nnoremap <leader>za :action ExpandCollapseToggleAction<CR>
nnoremap <leader>zR :action ExpandAllRegions<CR>
nnoremap <leader>zM :action CollapseAllRegions<CR>
nnoremap <leader>zr :action ExpandRegion<CR>
nnoremap <leader>zm :action CollapseRegion<CR>

" -----------------------------------------------------------------------------
" Build/Run/Debug - synced with terminal.lua
" -----------------------------------------------------------------------------
nnoremap <leader>rr :action RunClass<CR>
nnoremap <leader>rd :action Debug<CR>
nnoremap <leader>rs :action Stop<CR>
nnoremap <leader>rb :action Android.SyncProject<CR>
nnoremap <leader>rp :action RunProject<CR>

" Overseer/Task Commands - synced with overseer.nvim
nnoremap <leader>oo :action ActivateRunToolWindow<CR>
nnoremap <leader>or :action RunAnything<CR>
nnoremap <leader>ob :action MakeProject<CR>
nnoremap <leader>oi :action EditConfigurations<CR>

" Testing Commands - synced with vim-test.lua
nnoremap <leader>ten :action RunClass<CR>
nnoremap <leader>tenf :action RunClass<CR>
nnoremap <leader>tena :action RunAll<CR>
nnoremap <leader>tenl :action Rerun<CR>

" -----------------------------------------------------------------------------
" Flutter Commands - synced with flutter-tools.lua (fl* prefix)
" -----------------------------------------------------------------------------
nnoremap <leader>flr :action Flutter.HotReload<CR>
nnoremap <leader>fls :action Flutter.Restart<CR>
nnoremap <leader>fld :action Flutter.Open.DevTools<CR>
nnoremap <leader>fla :action Run<CR>
nnoremap <leader>flsd :action DeviceAndSnapshotComboBox<CR>
nnoremap <leader>fle :action AvdManager<CR>
nnoremap <leader>flq :action Stop<CR>
nnoremap <leader>flo :action ActivateStructureToolWindow<CR>
nnoremap <leader>flc :action AndroidLogcatToolWindowFactory.CloseLogcatConsole<CR>

" -----------------------------------------------------------------------------
" Window Management (Splits) - synced with session-workspace.lua
" -----------------------------------------------------------------------------
nnoremap <leader>sv :action SplitVertically<CR>
nnoremap <leader>sh :action SplitHorizontally<CR>
nnoremap <leader>sc :action Unsplit<CR>
nnoremap <leader>so :action UnsplitAll<CR>
nnoremap <leader>_ :action MaximizeEditorInSplit<CR>
nnoremap <leader>wm :action MoveEditorToOppositeTabGroup<CR>
nnoremap <leader>we :action NextSplitter<CR>
nnoremap <leader>wt :action PrevSplitter<CR>

" Project Management - synced with session-workspace.lua
nnoremap <leader>fp :action ManageRecentProjects<CR>

" Session Management - synced with persistence.nvim
nnoremap <leader>qs :action RestoreSession<CR>
nnoremap <leader>ql :action RestoreLastSession<CR>
nnoremap <leader>qd :action StopSession<CR>

" Zen Mode - synced with zen-mode.nvim
nnoremap <leader>zz :action ToggleFullScreen<CR>

" -----------------------------------------------------------------------------
" End of .ideavimrc
" -----------------------------------------------------------------------------
" Location:
"   macOS/Linux: ~/.ideavimrc
"   Windows: %USERPROFILE%\_ideavimrc
" Reload with ':source ~/.ideavimrc' or restart the IDE.
" Use ':actionlist [filter]' to search for more actions.
