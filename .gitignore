# Ignora todo
*

# No ignores archivos específicos
!.vimrc
!.ideavimrc
!vimNotes.txt
!vimNotes.md
!README.md
!.gitignore

# Neovim config
!.config/
!.config/nvim/
!.config/nvim/**

# Ignorar plugins clonados (packer, plug, etc.)
.config/nvim/pack/
.config/nvim/plugin/packer_compiled.lua

# Archivos basura del sistema
*.DS_Store
Thumbs.db
.directory

# Archivos con datos sensibles - NUNCA commitear
.zshrc
.bashrc
.bash_profile
.zprofile
.env
.env.*
.envrc
*.key
*.pem
*_rsa
*_dsa
secrets*
credentials*

# Vim state files con historial de paths
.vim/.netrwhist
.viminfo

# Plugin lock files (regenerables)
.config/nvim/lazy-lock.json
